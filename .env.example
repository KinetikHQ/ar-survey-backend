# ──────────────────────────────────────────────
# AR Survey & Inspection — Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# Database — SQLite for local dev, Postgres for Docker/production
DATABASE_URL=sqlite:///./ar_survey.db
# DATABASE_URL=postgresql://arsurvey:password@localhost:5432/ar_survey

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ar-survey-clips
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Auth
API_KEY=dev-api-key-change-in-prod

# AI Worker
MODEL_DEVICE=cpu
SAM_MODEL=vit_b
FRAME_SAMPLE_RATE=1

# Dev upload URL — use your PC's local IP for phone access
DEV_UPLOAD_BASE_URL=http://192.168.0.186:8000
